{
  "name": "mayhem-systems-discord-control",
  "version": "2.0.0",
  "description": "Mayhem Systems Discord Control — All-in-one Discord bot with web dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prestart": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "node --experimental-sqlite node_modules/ts-node/bin/ts-node src/index.ts",
    "watch": "node --experimental-sqlite node_modules/ts-node-dev/bin/ts-node-dev --respawn src/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "axios": "^1.6.7",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
